{
  "name": "@syncframe/redis",
  "version": "0.2.1",
  "description": "Redis-backed SyncStore + SyncTransport adapters for @syncframe/core",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "syncframe",
    "redis",
    "ioredis",
    "pubsub",
    "sync",
    "realtime"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkvc/syncframe.git",
    "directory": "packages/redis"
  },
  "homepage": "https://syncframe.jkvc.ai/",
  "bugs": "https://github.com/jkvc/syncframe/issues",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@syncframe/core": "workspace:^"
  },
  "peerDependencies": {
    "ioredis": "^5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ioredis": "^5.11.1",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
