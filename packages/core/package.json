{
  "name": "@syncframe/core",
  "version": "0.2.3",
  "description": "Anchor-based dead-reckoning sync library — Layer 1 (time-event protocol)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "sync",
    "dead-reckoning",
    "clock-sync",
    "realtime",
    "anchor",
    "extrapolation",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkvc/syncframe.git",
    "directory": "packages/core"
  },
  "homepage": "https://syncframe.jkvc.ai/",
  "bugs": "https://github.com/jkvc/syncframe/issues",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server-entry.ts",
    "./react": "./src/react-entry.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "react": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.js"
      }
    }
  }
}
